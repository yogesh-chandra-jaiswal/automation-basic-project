<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO" packages="org.apache.logging.log4j.core">
    <Properties>
        <Property name="log.dir">target/logs</Property>
        <Property name="log.pattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5p %c{1}:%L - %m%n</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${log.pattern}" />
            <ThresholdFilter level="INFO" />
        </Console>

        <!-- File Appender for All Logs -->
        <RollingFile name="RollingFile"
                     fileName="${log.dir}/automation.log"
                     filePattern="${log.dir}/automation-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${log.pattern}" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
                <SizeBasedTriggeringPolicy size="10MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
            <ThresholdFilter level="DEBUG" />
        </RollingFile>

        <!-- File Appender for Errors Only -->
        <RollingFile name="ErrorFile"
                     fileName="${log.dir}/error.log"
                     filePattern="${log.dir}/error-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${log.pattern}" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
                <SizeBasedTriggeringPolicy size="10MB" />
            </Policies>
            <DefaultRolloverStrategy max="5" />
            <ThresholdFilter level="ERROR" onMismatch="DENY" />
        </RollingFile>

        <!-- File Appender for Info Only -->
        <RollingFile name="InfoFile"
                     fileName="${log.dir}/info.log"
                     filePattern="${log.dir}/info-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${log.pattern}" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
                <SizeBasedTriggeringPolicy size="10MB" />
            </Policies>
            <DefaultRolloverStrategy max="5" />
            <LevelRangeFilter minLevel="INFO" maxLevel="INFO" onMismatch="DENY" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
            <AppenderRef ref="ErrorFile" />
            <AppenderRef ref="InfoFile" />
        </Root>

        <!-- Selenium Logger -->
        <Logger name="org.openqa.selenium" level="WARN" />

        <!-- Apache Commons Logger -->
        <Logger name="org.apache.commons" level="WARN" />

        <!-- Cucumber Logger -->
        <Logger name="io.cucumber" level="INFO" />

        <!-- Test Loggers -->
        <Logger name="common" level="DEBUG" />
        <Logger name="pages" level="DEBUG" />
        <Logger name="steps" level="DEBUG" />
        <Logger name="hooks" level="DEBUG" />
        <Logger name="utils" level="DEBUG" />
    </Loggers>
</Configuration>

